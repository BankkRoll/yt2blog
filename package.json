{
  "name": "yt2blog",
  "version": "1.0.2",
  "description": "Transform YouTube videos into polished blog posts using AI",
  "type": "module",
  "main": "./dist/lib.js",
  "module": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "bin": {
    "yt2blog": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "start": "node dist/cli.js",
    "format": "prettier ./src --write",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "youtube",
    "blog",
    "ai",
    "cli",
    "transcript",
    "content",
    "generator",
    "openai",
    "anthropic",
    "gpt",
    "claude",
    "vercel-ai-sdk",
    "whisper",
    "transcription"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BankkRoll/yt2blog.git"
  },
  "homepage": "https://github.com/BankkRoll/yt2blog#readme",
  "bugs": {
    "url": "https://github.com/BankkRoll/yt2blog/issues"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "ai": "^5.0.0",
    "clipboardy": "^5.3.1",
    "dotenv": "^16.6.1",
    "form-data": "^4.0.5",
    "ink": "^5.1.0",
    "node-fetch": "3",
    "react": "^18.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
