# yt2blog Environment Variables
#
# You can set these variables in multiple ways:
# 1. Copy this file to .env and fill in values (recommended)
# 2. Export in your shell: export AI_GATEWAY_API_KEY=...
# 3. Inline with command: AI_GATEWAY_API_KEY=... pnpm dev
# 4. Set as system environment variables

# ═══════════════════════════════════════════════════════════════════════════════
# AI GATEWAY (Recommended)
# ═══════════════════════════════════════════════════════════════════════════════
# Get your key from https://vercel.com/dashboard -> AI Gateway
# This gives you access to all providers through a single key
AI_GATEWAY_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# PROVIDER-SPECIFIC KEYS
# ═══════════════════════════════════════════════════════════════════════════════
# Only needed if NOT using AI Gateway, or for Whisper transcription fallback
# Set only the keys for providers you want to use

# OpenAI (also used for Whisper transcription fallback)
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini)
GOOGLE_API_KEY=

# Groq
GROQ_API_KEY=gsk_...

# Mistral
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=pplx-...

# xAI (Grok)
XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# APP SETTINGS (Optional)
# ═══════════════════════════════════════════════════════════════════════════════
# Default theme: default, dracula, nord, catppuccin, tokyo-night, monokai,
#                high-contrast, neo-brutalism, windows-98
YT2BLOG_THEME=default
